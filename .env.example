# ── Flask ──────────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string

# ── Gmail SMTP (password reset e-mails) ────────────────────────────────────────
# 1. Use a Gmail account you control (or create one just for this app).
# 2. Enable 2-Step Verification on that account:
#    https://myaccount.google.com/security
# 3. Create an App Password (Security → App passwords → "Mail" + "Other"):
#    https://myaccount.google.com/apppasswords
#    You'll get a 16-character code — paste it as SMTP_PASS (without spaces).
SMTP_USER=yourapp@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Optional overrides (defaults shown)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=yourapp@gmail.com

# ── AI (Qwen / DashScope) ──────────────────────────────────────────────────────
DASHSCOPE_API_KEY=your-dashscope-api-key-here
